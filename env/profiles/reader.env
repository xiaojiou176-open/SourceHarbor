# Reader stack profile (Miniflux + Nextflux)
# Usage:
#   cp env/profiles/reader.env env/profiles/reader.local.env
#   ./scripts/deploy/reader_stack.sh up --env-file env/profiles/reader.local.env
# Notes:
# - This tracked file is a placeholder-only template.
# - Put real passwords/tokens in env/profiles/reader.local.env (ignored by git).

MINIFLUX_DB_PASSWORD=change_me
MINIFLUX_ADMIN_USERNAME=admin
MINIFLUX_ADMIN_PASSWORD=change_me
MINIFLUX_BASE_URL=http://127.0.0.1:8080
NEXTFLUX_PORT=3000
MINIFLUX_POLLING_FREQUENCY=30
MINIFLUX_CLEANUP_ARCHIVE_READ_DAYS=30
MINIFLUX_CLEANUP_REMOVE_SESSIONS_DAYS=30

# Optional for AI feed sync:
# MINIFLUX_API_TOKEN=
