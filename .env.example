# Root operator environment example.
# Copy this file to `.env` and add only the variables you need locally.
# Shared defaults live in `env/core.env.example`.

export CI=false
export SOURCE_HARBOR_CACHE_ROOT="${SOURCE_HARBOR_CACHE_ROOT:-$HOME/.cache/sourceharbor}"
export CORE_POSTGRES_PORT="${CORE_POSTGRES_PORT:-15432}"
export DATABASE_URL="postgresql+psycopg://postgres:postgres@127.0.0.1:${CORE_POSTGRES_PORT}/sourceharbor"
export PIPELINE_ARTIFACT_ROOT="${PIPELINE_ARTIFACT_ROOT:-$SOURCE_HARBOR_CACHE_ROOT/artifacts}"
export PIPELINE_WORKSPACE_DIR="${PIPELINE_WORKSPACE_DIR:-$SOURCE_HARBOR_CACHE_ROOT/workspace}"
export SOURCE_HARBOR_API_BASE_URL=http://127.0.0.1:9000
export SOURCE_HARBOR_PUBLIC_SITE_URL=
export SOURCE_HARBOR_REPO_ROOT=.
export SQLITE_PATH="${SQLITE_PATH:-$SOURCE_HARBOR_CACHE_ROOT/state/worker_state.db}"
export SQLITE_STATE_PATH="${SQLITE_STATE_PATH:-$SOURCE_HARBOR_CACHE_ROOT/state/api_state.db}"
export TEMPORAL_NAMESPACE=default
export TEMPORAL_TARGET_HOST=127.0.0.1:7233
export TEMPORAL_TASK_QUEUE=sourceharbor-worker
export UV_PROJECT_ENVIRONMENT="${UV_PROJECT_ENVIRONMENT:-$SOURCE_HARBOR_CACHE_ROOT/project-venv}"
export WEB_E2E_NEXT_DIST_DIR=apps/web/.next
export WEB_E2E_RUNTIME_WEB_DIR=.runtime-cache/tmp/web-runtime/workspace/apps/web
export WEB_E2E_USE_MOCK_API=1
export WEB_RUNTIME_WEB_DIR=.runtime-cache/tmp/web-runtime/workspace/apps/web
export SOURCE_HARBOR_CHROME_USER_DATA_DIR="${SOURCE_HARBOR_CHROME_USER_DATA_DIR:-$SOURCE_HARBOR_CACHE_ROOT/browser/chrome-user-data}"
export SOURCE_HARBOR_CHROME_PROFILE_NAME="${SOURCE_HARBOR_CHROME_PROFILE_NAME:-sourceharbor}"
export SOURCE_HARBOR_CHROME_PROFILE_DIR="${SOURCE_HARBOR_CHROME_PROFILE_DIR:-Profile 1}"
export SOURCE_HARBOR_CHROME_CDP_PORT="${SOURCE_HARBOR_CHROME_CDP_PORT:-9339}"

# Optional provider keys
export GEMINI_API_KEY=
export YOUTUBE_API_KEY=
export RESEND_API_KEY=
export RESEND_FROM_EMAIL=
